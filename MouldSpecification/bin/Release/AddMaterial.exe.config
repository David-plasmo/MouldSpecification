<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<System.Windows.Forms.ApplicationConfigurationSection>
		<add key="DpiAwareness" value="PerMonitorV2" />
	</System.Windows.Forms.ApplicationConfigurationSection>
	
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
	<connectionStrings>
		<add name="default" connectionString="Data Source=PLASMO-SQL;Initial Catalog=InjectionMouldMAN;Integrated Security=True" providerName="System.Data.SqlClient"/>
		<add name="defaultSPECTRE" connectionString="Data Source=SPECTRE;Initial Catalog=InjectionMouldMAN;Integrated Security=True" providerName="System.Data.SqlClient"/>
		<add name="defaultDAVIDALLINONE" connectionString="Data Source=DAVIDALLINONE\SQLEXPRESS;Initial Catalog=InjectionMouldMAN;Integrated Security=True" providerName="System.Data.SqlClient"/>
		<add name="defaultPLASMO-DB-01" connectionString="Data Source=PLASMO-DB-01;Initial Catalog=InjectionMouldMAN;Integrated Security=True" providerName="System.Data.SqlClient"/>
		<add name="Admin" connectionString="Data Source=PLASMO-DB-01;Initial Catalog=PlasmoAdmin;Integrated Security=True" providerName="System.Data.SqlClient"/>
	</connectionStrings>

</configuration>